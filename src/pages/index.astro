---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ConvictionEngine from '../components/ConvictionEngine.astro';
import NowShipping from '../components/NowShipping.astro';
import Stats from '../components/Stats.astro';
import ProofShelf from '../components/ProofShelf.astro';
import HowWeWork from '../components/HowWeWork.astro';
import WhatWeBuild from '../components/WhatWeBuild.astro';
import Team from '../components/Team.astro';
import PullQuote from '../components/PullQuote.astro';
import Engage from '../components/Engage.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Straw Dogs Development—Boutique Ghostwriting & Book Architecture">
  <Nav cross={{ label: "For Partners", href: "/partners/" }} />
  <main>
    <Hero />
    <NowShipping />
    <ConvictionEngine />
    <ProofShelf />
    <HowWeWork />
    <WhatWeBuild />
    <Team />
    <Stats />
    <PullQuote image="/images/mountain.jpg" cite="Platte F. Clark">
      &ldquo;<span class="display-italic">Facts inform.</span> Meaning transforms. The gap between the two is closeable not by talent, but by <span class="display-italic">architecture.</span>&rdquo;
    </PullQuote>
    <Engage />
  </main>
  <Footer />
</BaseLayout>

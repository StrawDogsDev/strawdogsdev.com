  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
    <p class="text-xs tracking-[0.18em] uppercase text-navy-muted">
      Straw Dogs LLC &middot; {year}
    </p>
    <p class="text-xs italic text-navy-muted">
      Story is a technology. Not a talent.
    </p>
  </div>
</footer>

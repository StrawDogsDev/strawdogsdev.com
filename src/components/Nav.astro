---
interface Link { label: string; href: string; }
interface Props {
  links?: Link[];
  cta?: Link;
  cross?: Link;
}
const {
  links = [
    { label: "The Method", href: "#method" },
    { label: "The Work", href: "#work" },
    { label: "The Team", href: "#team" },
  ],
  cta = { label: "Start a Project", href: "#engage" },
  cross,
} = Astro.props;
---

<nav class="nav">
  <div class="nav-inner">
    <a class="brand" href="/" aria-label="Straw Dogs Development home">
      <img class="brand-mark" src="/images/dog-mark.png" alt="" width="363" height="238" />
      <span class="wordmark">Straw Dogs <span class="wm-sub">Development</span></span>
    </a>

    <div class="nav-links">
      {links.map((l) => <a class="nav-link" href={l.href}>{l.label}</a>)}
      {cross && <a class="nav-link nav-cross" href={cross.href}>{cross.label} →</a>}
      <a class="nav-cta" href={cta.href}>{cta.label}</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(244, 240, 230, 0.82);
    -webkit-backdrop-filter: blur(10px) saturate(1.2);
    backdrop-filter: blur(10px) saturate(1.2);
    border-bottom: 1px solid var(--color-rule);
  }
  .nav-inner {
    max-width: 1120px; margin: 0 auto; padding: 0.85rem 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .brand { display: flex; align-items: center; gap: 0.65rem; text-decoration: none; }
  .brand-mark { height: 28px; width: auto; display: block; }
  .wordmark {
    font-size: 0.72rem; letter-spacing: 0.26em; text-transform: uppercase;
    font-weight: 600; color: var(--color-ink);
  }
  .wordmark .wm-sub { color: var(--color-ink-mute); font-weight: 500; }
  .nav-links { display: flex; align-items: center; gap: 1.6rem; }
  .nav-link {
    font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--color-ink-soft); text-decoration: none; transition: color 0.3s ease;
  }
  .nav-link:hover { color: var(--color-blue); }
  .nav-cross { color: var(--color-ink-mute); }
  .nav-cta {
    font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600;
    color: #fff; background: var(--color-blue); padding: 0.55rem 1rem; border-radius: 2px;
    text-decoration: none; transition: background 0.3s ease;
  }
  .nav-cta:hover { background: var(--color-blue-deep); }
  @media (max-width: 860px) {
    .nav-link { display: none; }
    .nav-cross { display: none; }
  }
</style>

---
const engines = [
  { number: "01", name: "Conflict", label: "The attentional gate",
    body: "Without a gap between what is and what should be, the reader's brain never engages. We open with tension, not information." },
  { number: "02", name: "Character", label: "A before-state to inhabit",
    body: "The reader must see themselves in the protagonist's position before transformation — or they observe the book instead of entering it." },
  { number: "03", name: "Change", label: "The identity shift",
    body: "Not new information. A new answer to who am I. The books that change people make the old version of the reader impossible to return to." },
  { number: "04", name: "Stakes", label: "The cost of not moving",
    body: "Without felt consequence, a book is an anecdote. With it, the book becomes an argument the reader makes to themselves about why they have to act." },
];
---

<section id="method" class="section fade-in">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow" style="display:block; margin-bottom:1rem;">The Method</span>
      <h2 class="h2" style="margin-bottom:1.5rem;">The Four Narrative Engines<span class="tm">&trade;</span></h2>
      <p class="lede" style="font-size:clamp(1.05rem,1.8vw,1.35rem);">
        AI is about to create the greatest sea of sameness we've ever experienced. How do you rise
        above that and stand out? <span style="color:var(--color-blue); font-style:normal; font-weight:500;">You engage the Four Narrative Engines.</span>
      </p>
    </div>

    <div class="engine-grid">
      {engines.map((e) => (
        <article class="card card-hover engine">
          <div class="engine-meta">
            <span class="engine-num">{e.number}</span>
            <span class="engine-bar"></span>
            <span class="engine-name">{e.name}</span>
          </div>
          <h3 class="h3" style="margin-bottom:1rem;">{e.label}</h3>
          <p class="body-text" style="font-size:0.97rem;">{e.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .engine-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .engine { padding: 2.1rem 2.2rem 2.3rem; }
  .engine-meta { display: flex; align-items: center; gap: 0.85rem; margin-bottom: 1.4rem; }
  .engine-num { font-family: var(--font-body); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em; color: var(--color-blue); }
  .engine-bar { flex: 1; height: 1px; background: var(--color-rule); transition: background 0.45s ease; }
  .engine:hover .engine-bar { background: var(--color-blue); }
  .engine-name { font-family: var(--font-body); font-size: 0.66rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-ink-mute); }
  @media (max-width: 720px) { .engine-grid { grid-template-columns: 1fr; } }
</style>

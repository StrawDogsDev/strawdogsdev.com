            </a>
          </li>
          <li>
            <a href="tel:8016422453" class="hover:text-gold transition-colors">
              801 &middot; 642 &middot; 2453
            </a>
          </li>
          <li class="text-sm text-navy-muted pt-2">
            Straw Dogs LLC<br/>American Fork, Utah
          </li>
        </ul>

<section id="contact" class="border-t border-rule py-20 sm:py-28 px-6 fade-in">
  <div class="max-w-6xl mx-auto">
    <p class="eyebrow mb-3">/ Contact</p>
    <h2 class="display text-4xl sm:text-5xl md:text-6xl leading-[1.05] mb-14 text-balance" style="font-weight: 500;">
      Start a conversation about a <span class="display-italic" style="font-weight: 500;">manuscript</span>.
    </h2>

    <div class="grid md:grid-cols-3 gap-10 lg:gap-12">
      <!-- Direct -->
      <div class="surface rounded-sm p-7">
        <div class="flex items-center gap-3 mb-5">
          <span class="font-mono text-xs text-copper">01</span>
          <span class="copper-rule flex-1 opacity-30"></span>
          <span class="font-mono text-[0.65rem] tracking-[0.12em] uppercase text-bone-mute">Direct</span>
        </div>
        <ul class="space-y-3 text-bone-soft">
          <li>
            <a href="mailto:platte@strawdogsdev.com" class="text-bone hover:text-copper transition-colors break-all">
              platte@strawdogsdev.com
            </a>
          </li>
          <li>
            <a href="tel:8016422453" class="font-mono text-bone-soft hover:text-copper transition-colors">
              801 / 642 / 2453
            </a>
          </li>
          <li class="font-mono text-xs text-bone-mute pt-2 leading-relaxed tracking-wide">
            STRAW DOGS LLC<br/>AMERICAN FORK, UTAH
          </li>
        </ul>
      </div>

      <!-- Brand -->
      <div class="surface rounded-sm p-7">
        <div class="flex items-center gap-3 mb-5">
          <span class="font-mono text-xs text-copper">02</span>
          <span class="copper-rule flex-1 opacity-30"></span>
          <span class="font-mono text-[0.65rem] tracking-[0.12em] uppercase text-bone-mute">Across the Brand</span>
        </div>
        <ul class="space-y-4">
          <li>
            <a href="https://platteclark.com" target="_blank" rel="noopener" class="text-bone hover:text-copper transition-colors inline-flex items-center gap-1.5">
              platteclark.com
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                <path d="M3 3L9 9M9 3v6H3" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
              </svg>
            </a>
            <p class="text-sm text-bone-mute mt-0.5">Principal's site &amp; Compass</p>
          </li>
          <li>
            <a href="https://authorunknown.fm" target="_blank" rel="noopener" class="text-bone hover:text-copper transition-colors inline-flex items-center gap-1.5">
              authorunknown.fm
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                <path d="M3 3L9 9M9 3v6H3" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/>
              </svg>
            </a>
            <p class="text-sm text-bone-mute mt-0.5">The podcast</p>
          </li>
        </ul>
      </div>

      <!-- Representation -->
      <div class="surface rounded-sm p-7">
        <div class="flex items-center gap-3 mb-5">
          <span class="font-mono text-xs text-copper">03</span>
          <span class="copper-rule flex-1 opacity-30"></span>
          <span class="font-mono text-[0.65rem] tracking-[0.12em] uppercase text-bone-mute">Representation</span>
        </div>
        <ul class="space-y-4 text-sm">
          <li>
            <span class="font-medium text-bone">Grey + Miller</span>
            <span class="block text-bone-mute font-mono text-xs tracking-wide mt-0.5">NON-FICTION</span>
          </li>
          <li>
            <span class="font-medium text-bone">East West Literary</span>
            <span class="block text-bone-mute font-mono text-xs tracking-wide mt-0.5">FICTION</span>
          </li>
          <li>
            <span class="font-medium text-bone">plain text Talent</span>
            <span class="block text-bone-mute font-mono text-xs tracking-wide mt-0.5">FILM / TV</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

      <div class="border-t border-rule-strong pt-5">
        <h3 class="text-xs tracking-[0.22em] uppercase font-semibold mb-4">Direct</h3>
        <ul class="space-y-2 text-navy-soft">
          <li>
            <a href="mailto:platte@strawdogsdev.com" class="hover:text-gold transition-colors">

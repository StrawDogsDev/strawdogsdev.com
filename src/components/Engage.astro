---
const compass = [
  { name: "Aggregator", desc: "Collector of the wisdom of others." },
  { name: "Apothegist", desc: "Anchors modern best practices to classical wisdom." },
  { name: "Author", desc: "Surfaces best practices from personal experience." },
  { name: "Academic", desc: "Ivory tower with lots of footnotes." },
  { name: "Actor", desc: "In the trenches learning from the real world." },
];
const diagnostic = [
  "Conviction Engine evaluation",
  "Agentic beta reader review",
  "Detailed revision roadmap",
  "One-hour debrief and Q&A",
];
---

<section id="engage" class="section fade-in">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow" style="display:block; margin-bottom:1rem;">Engage</span>
      <h2 class="h2" style="margin-bottom:1.5rem;">Three doors. <span class="display-italic">Pick one.</span></h2>
      <p class="lede" style="font-size:clamp(1.05rem,1.7vw,1.3rem);">
        The advice is good whether we work together or not.
      </p>
    </div>

    <div class="doors">
      <article class="card door">
        <div class="door-top">
          <span class="door-no">Door One</span>
          <span class="door-price free">Free · 10 min</span>
        </div>
        <h3 class="h3" style="margin-bottom:0.8rem;">The Thought Leader Compass</h3>
        <p class="body-text" style="margin:0 0 1.4rem;">
          Twenty questions. A written read of your authority profile&mdash;your Primary and
          Secondary types, and the kind of book those styles produce.
        </p>
        <ul class="compass">
          {compass.map((c) => (
            <li><span class="c-name">{c.name}</span><span class="c-desc">{c.desc}</span></li>
          ))}
        </ul>
        <a class="link-arrow" href="https://platteclark.com/assessment" target="_blank" rel="noopener" style="margin-top:1.5rem;">Take the Compass ↗</a>
      </article>

      <article class="card door">
        <div class="door-top">
          <span class="door-no">Door Two</span>
          <span class="door-price">$750 · 3 hrs</span>
        </div>
        <h3 class="h3" style="margin-bottom:0.8rem;">Deep Dive Analysis + 1:1 Strategy Session</h3>
        <p class="body-text" style="margin:0 0 1.2rem;">
          Two hours of preparatory analysis, then a one-hour live session. You leave with a
          defensible next move on a manuscript, book proposal, narrative, or training concept.
        </p>
        <a class="link-arrow" href="https://calendly.com/platte/one-on-one-book-coaching-call" target="_blank" rel="noopener">Book your session ↗</a>
      </article>

      <article class="card door">
        <div class="door-top">
          <span class="door-no">Door Three</span>
          <span class="door-price">Project Engagement</span>
        </div>
        <h3 class="h3" style="margin-bottom:0.8rem;">The Complete Manuscript Diagnostic</h3>
        <p class="body-text" style="margin:0 0 1.2rem;">
          The full Straw Dogs read on a draft manuscript. Four components:
        </p>
        <ol class="diag">
          {diagnostic.map((d, i) => <li><span>{i + 1}</span>{d}</li>)}
        </ol>
        <a class="link-arrow" href="mailto:platte@strawdogsdev.com" style="margin-top:1.4rem;">Email for details →</a>
      </article>
    </div>

    <div class="card-invert start">
      <div>
        <p class="eyebrow" style="display:block; margin-bottom:0.8rem;">Start a Project</p>
        <h3 class="h3" style="color:#f4f1ea; font-style:italic; margin-bottom:0.8rem;">Or just talk to us about your book.</h3>
        <p class="on-dark-soft" style="line-height:1.6; margin:0; max-width:52ch;">
          A book deal, a draft, an idea on a napkin, or just the conviction that you want to write
          something that lasts. We'll listen, ask the questions that matter, and help you craft a
          message worthy of your expertise.
        </p>
      </div>
      <div class="start-actions">
        <a class="btn btn-solid" href="https://calendly.com/platte/progressing_your_book" target="_blank" rel="noopener" style="background:#fff; color:var(--color-blue);">Schedule a conversation</a>
        <a class="start-contact" href="mailto:platte@strawdogsdev.com">platte@strawdogsdev.com</a>
        <a class="start-contact" href="tel:8016422453">801 · 642 · 2453</a>
      </div>
    </div>
  </div>
</section>

<style>
  .doors { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-bottom: 1.25rem; }
  .door { padding: 2rem 1.9rem 2.1rem; display: flex; flex-direction: column; }
  .door-top { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; margin-bottom: 1.3rem; }
  .door-no { font-family: var(--font-body); font-size: 0.66rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-ink); }
  .door-price { font-family: var(--font-body); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #fff; background: var(--color-blue); padding: 0.3rem 0.6rem; border-radius: 2px; white-space: nowrap; }
  .door-price.free { background: var(--color-ink); }
  .compass { list-style: none; margin: 0; padding: 1rem 0 0; border-top: 1px solid var(--color-rule); }
  .compass li { display: grid; grid-template-columns: 7rem 1fr; gap: 0.6rem; padding: 0.45rem 0; align-items: baseline; }
  .c-name { font-family: var(--font-display); font-style: italic; font-size: 0.95rem; color: var(--color-ink); font-variation-settings: "opsz" 30; }
  .c-desc { font-size: 0.78rem; color: var(--color-ink-mute); line-height: 1.35; }
  .diag { list-style: none; margin: 0; padding: 0; counter-reset: d; }
  .diag li { display: flex; align-items: baseline; gap: 0.7rem; padding: 0.4rem 0; font-size: 0.9rem; color: var(--color-ink-soft); }
  .diag li span { font-family: var(--font-body); font-size: 0.66rem; font-weight: 700; color: var(--color-blue); border: 1px solid var(--color-rule-strong); border-radius: 50%; width: 1.3rem; height: 1.3rem; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .door .link-arrow { margin-top: auto; }
  .start { padding: 2.4rem; display: grid; grid-template-columns: 1.4fr 1fr; gap: 2rem; align-items: center; }
  .start-actions { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .start-contact { font-family: var(--font-body); font-size: 0.85rem; color: #c7d0ff; text-decoration: none; transition: color 0.3s ease; }
  .start-contact:hover { color: #fff; }
  @media (max-width: 860px) { .doors { grid-template-columns: 1fr; } .start { grid-template-columns: 1fr; } }
</style>

---
const models = [
  {
    code: "01",
    title: "Referral Network",
    body: "We refer authors who need your packaging, distribution, and marketing engine. You refer authors who arrive needing a writer. Standard industry referral terms (typically 10%) apply both directions.",
  },
  {
    code: "02",
    title: "White-Label Engine",
    body: "We function as your in-house ghostwriting capability under your imprint. The author works with us; the credit, the relationship, and the book belong to your house.",
  },
  {
    code: "03",
    title: "Project Engagement",
    body: "Direct, scoped, by deliverable. Full ghostwrite, framework architecture, manuscript repair, or developmental edit—priced by the hours the work actually demands.",
  },
];
---

<section class="border-t border-rule py-20 sm:py-28 px-6 fade-in">
  <div class="max-w-6xl mx-auto">
    <div class="mb-14 sm:mb-16">
      <p class="eyebrow mb-3">/ Engagement Models</p>
      <h2 class="display text-4xl sm:text-5xl md:text-6xl leading-[1.05]" style="font-weight: 500;">
        How publishers <span class="display-italic" style="font-weight: 500;">work with us</span>.
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-5 lg:gap-6">
      {models.map((m) => (
        <div class="surface rounded-sm p-7 sm:p-8 group hover:surface-glow transition-all duration-500">
          <div class="flex items-center gap-3 mb-5">
            <span class="font-mono text-xs tracking-[0.18em] text-copper">{m.code}</span>
            <span class="copper-rule flex-1 opacity-30 group-hover:opacity-100 transition-opacity duration-500"></span>
          </div>
          <h3 class="heading text-xl mb-4 text-bone uppercase tracking-[0.04em]">{m.title}</h3>
          <p class="text-bone-soft leading-relaxed text-[0.95rem]">{m.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

  .team-role { font-family: var(--font-body); font-size: 0.66rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-blue); margin: 0.45rem 0 0; }
  .team-rate { font-family: var(--font-display); font-size: 1.6rem; color: var(--color-ink); white-space: nowrap; font-variation-settings: "opsz" 60; }

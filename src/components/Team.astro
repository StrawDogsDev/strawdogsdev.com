  .team-bio p { color: var(--color-ink-soft); line-height: 1.62; font-size: 0.95rem; margin: 0 0 0.9rem; }
  .team-bio p:last-child { margin-bottom: 0; }
  .team-bio em { font-style: italic; color: var(--color-ink); }
  @media (max-width: 760px) { .team-grid { grid-template-columns: 1fr; } }

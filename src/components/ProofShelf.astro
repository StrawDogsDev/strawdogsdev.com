---
const featured = [
  {
    title: "The Best Christmas Pageant Ever",
    detail: "Lionsgate, 2024",
    credit: "Credited screenwriter",
    note: "92% Critics / 97% Audiences. Top-40 box office. Studio film as deliverable."
  },
  {
    title: "The Bad Unicorn Trilogy",
    detail: "Aladdin / Simon & Schuster",
    credit: "250K+ trade copies sold",
    note: "Big Five fiction, three-book deal. Demonstrates load-bearing series architecture."
  },
];

const books = [
  { title: "The Leader's Guide to Unconscious Bias", detail: "Fuller, Murphy, Anne Chow (CEO, AT&T Business)", publisher: "FranklinCovey" },
  { title: "Master Mentors, Vols. 1 & 2", detail: "Scott Jeffrey Miller", publisher: "FranklinCovey" },
  { title: "Get Better", detail: "Todd Davis, CPO, FranklinCovey", publisher: "FranklinCovey" },
  { title: "Leading Loyalty", detail: "Rogers, Rinne, Moon", publisher: "FranklinCovey" },
  { title: "The Mind Strength Playbook", detail: "Luke Falk", publisher: "NFL QB & Mental-Strength Coach" },
  { title: "Deliver: Why Some Leaders Get Results & Most Don't", detail: "Hill, Jones, Corbridge", publisher: "" },
];

const forthcoming = "Schwedelson · Stacy · Client Giant · Fossler · Morris";
---

<section id="work" class="border-t border-rule py-20 sm:py-28 px-6 fade-in">
  <div class="max-w-6xl mx-auto">
    <div class="mb-14 sm:mb-16">
      <p class="eyebrow mb-3">/ Selected Proof Shelf</p>
      <h2 class="display text-4xl sm:text-5xl md:text-6xl leading-[1.05]" style="font-weight: 500;">
        A sample of <span class="display-italic" style="font-weight: 500;">the work</span>.
      </h2>
    </div>

    <!-- Featured cells (bento) -->
    <div class="grid md:grid-cols-2 gap-4 sm:gap-5 mb-5 sm:mb-6">
      {featured.map((b) => (
        <div class="surface-glow rounded-sm p-7 sm:p-8 flex flex-col gap-5">
          <div class="flex items-center gap-3">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-copper"></span>
            <span class="mono-label">/ Featured</span>
            <span class="copper-rule flex-1 opacity-30"></span>
          </div>
          <div>
            <h3 class="display text-2xl sm:text-3xl text-bone leading-tight mb-2" style="font-weight: 500;">{b.title}</h3>
            <p class="font-display italic text-bone-soft" style="font-variation-settings: 'opsz' 14;">{b.detail}</p>
          </div>
          <div class="mt-auto">
            <p class="font-mono text-[0.65rem] tracking-[0.14em] uppercase text-copper mb-2">{b.credit}</p>
            <p class="text-sm text-bone-soft leading-relaxed">{b.note}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Supporting grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-9">
      {books.map((b, i) => (
        <div class="border-t border-rule pt-4">
          <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-xs text-bone-mute tracking-wider">{String(i + 1).padStart(2, '0')}</span>
            <span class="copper-rule flex-1 opacity-30"></span>
          </div>
          <h3 class="display text-lg leading-snug mb-1.5 text-bone" style="font-weight: 500;">{b.title}</h3>
          <p class="text-sm text-bone-soft italic leading-snug" style="font-family: var(--font-display); font-variation-settings: 'opsz' 14;">{b.detail}</p>
          {b.publisher && (
            <p class="font-mono text-[0.65rem] tracking-[0.12em] uppercase text-bone-mute mt-2">{b.publisher}</p>
          )}
        </div>
      ))}
    </div>

    <div class="mt-14 pt-7 border-t border-rule-strong">
      <p class="eyebrow mb-3">/ Forthcoming, 2026</p>
      <p class="display italic text-2xl text-bone-soft" style="font-weight: 400; font-variation-settings: 'opsz' 144;">{forthcoming}</p>
    </div>
  </div>
</section>

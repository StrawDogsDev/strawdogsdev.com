---
const books = [
  { cat: "FranklinCovey", title: "The Leader's Guide to Unconscious Bias", who: "Pamela Fuller · Mark Murphy · Anne Chow", note: "Former CEO, AT&T Business · Wall Street Journal Bestseller" },
  { cat: "FranklinCovey", title: "Get Better", who: "Todd Davis", note: "Chief People Officer, FranklinCovey · Fifteen practices for relationships at work" },
  { cat: "FranklinCovey", title: "Master Mentors, Vols. 1 & 2", who: "Scott Jeffrey Miller", note: "Sixty transformative insights from leading minds" },
  { cat: "FranklinCovey", title: "Leading Loyalty", who: "Sandy Rogers · Leena Rinne · Shawn Moon", note: "Cracking the code to customer devotion" },
  { cat: "Memoir", title: "Loose Cannons", who: "Diana Cannon Ragsdale", note: "A literary family memoir" },
  { cat: "Sports · Mental Performance", title: "The Mind Strength Playbook", who: "Luke Falk", note: "Former NFL Quarterback · Mental-Strength Coach" },
  { cat: "#1 Bestseller · 2026", title: "Stupider People Have Done It", who: "Jay Schwedelson", note: "Marketing truths, career moves, and life advice for doers" },
  { cat: "Forthcoming · 2026", title: "The Pressure Code", who: "Jason Stacy", note: "Performance coach to Aryna Sabalenka and the WTA tour" },
  { cat: "Memoir", title: "Life is Luck", who: "John Morgan", note: "Founder, Morgan & Morgan · America's largest plaintiffs' firm" },
];
---

<section id="work" class="section fade-in">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow" style="display:block; margin-bottom:1rem;">Selected Work</span>
      <h2 class="h2" style="margin-bottom:1.5rem;">Books we've <span class="display-italic">built.</span></h2>
      <p class="lede" style="font-size:clamp(1.05rem,1.7vw,1.3rem);">
        Over thirty trade nonfiction titles across leadership, sales, marketing, sports performance,
        behavioral change, and memoir.
      </p>
    </div>

    <div class="book-grid">
      {books.map((b) => (
        <article class="card card-hover book">
          <p class="book-cat">{b.cat}</p>
          <h3 class="h3 book-title">{b.title}</h3>
          <p class="book-who">{b.who}</p>
          <p class="book-note">{b.note}</p>
        </article>
      ))}
    </div>

    <p class="other-work">
      <strong>Other recent and ongoing work</strong> includes <em>Automating Thoughtfulness</em>
      (Jay O'Brien & Jeff Jackel, co-founders of Client Giant); <em>Management Mess to Leadership
      Success</em>, <em>Marketing Mess to Brand Success</em>, <em>Career on Course</em>, and
      <em>Parenting Wrong Turns, Right Lessons</em> (Scott Jeffrey Miller, FranklinCovey);
      <em>Who Rocked the Boat</em> and <em>Change</em> (Curtis Bateman, FranklinCovey);
      <em>The Entrepreneur's Paradox</em> (Curtis Morley); <em>Deliver</em> (Hill, Jones, Corbridge);
      <em>The Ultimate Guide to Great Mentorship</em> (Scott Jeffrey Miller); <em>Hidden Value</em>
      (Dr. Keith Keating); and additional 2026 titles in development.
    </p>
  </div>
</section>

<style>
  .book-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }
  .book {
    padding: 1.7rem 1.7rem 1.9rem 2.3rem;
    display: flex; flex-direction: column;
    position: relative;
    background: linear-gradient(168deg, #dfe6f1 0%, #c8d3e4 100%);
    border-color: rgba(35, 55, 100, 0.28);
    box-shadow:
      0 12px 30px -20px rgba(20, 35, 75, 0.38),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
    overflow: hidden;
    transition: transform 0.45s ease, box-shadow 0.45s ease;
  }
  .book:hover {
    transform: translateY(-3px);
    box-shadow:
      0 16px 36px -18px rgba(20, 35, 75, 0.48),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
  }
  .book::before {
    content: "";
    position: absolute;
    top: 0; bottom: 0; left: 0;
    width: 6px;
    background: linear-gradient(180deg, #d4a35e 0%, var(--color-copper) 45%, #8a5f33 100%);
    box-shadow: inset -1px 0 0 rgba(15, 25, 55, 0.30);
    transition: width 0.45s ease;
  }
  .book:hover::before { width: 8px; }
  .book .book-cat { color: #1a2670; }
  .book .book-title, .book .book-who { color: #0e1a40; }
  .book .book-note { color: #4a546b; }
  .book-cat { font-family: var(--font-body); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-blue); margin: 0 0 1rem; }
  .book-title { font-size: clamp(1.2rem, 1.6vw, 1.45rem); margin: 0 0 0.7rem; }
  .book-who { font-family: var(--font-display); font-style: italic; font-variation-settings: "opsz" 30; color: var(--color-ink); font-size: 0.95rem; margin: 0 0 0.5rem; }
  .book-note { font-size: 0.82rem; color: var(--color-ink-mute); line-height: 1.45; margin: 0; }
  .other-work { margin: 2.5rem 0 0; padding-top: 2rem; border-top: 1px solid var(--color-rule); font-size: 0.9rem; line-height: 1.7; color: var(--color-ink-mute); }
  .other-work strong { color: var(--color-ink-soft); }
  .other-work em { font-style: italic; }
  @media (max-width: 860px) { .book-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .book-grid { grid-template-columns: 1fr; } }
</style>

---
const stats = [
  { figure: "~30", label: "Books Ghostwritten" },
  { figure: "250K+", label: "Trade Copies Sold (S&S)" },
  { figure: "92%", label: "Critics — Lionsgate, 2024" },
  { figure: "25", label: "Yrs Behavioral Curriculum" },
  { figure: "4", label: "Continents of Author Work" },
];
---

<section class="border-y border-rule-strong py-12 sm:py-14 px-6 fade-in relative overflow-hidden">
  <!-- Subtle gradient backdrop -->
  <div class="absolute inset-0 -z-10 pointer-events-none"
    style="background: linear-gradient(180deg, rgba(184, 133, 74, 0.04) 0%, transparent 50%, rgba(184, 133, 74, 0.04) 100%);">
  </div>

  <div class="max-w-6xl mx-auto">
    <div class="flex items-center gap-3 mb-8">
      <span class="mono-label">/ Track Record</span>
      <span class="copper-rule flex-1 opacity-30"></span>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-y-8 gap-x-6">
      {stats.map((stat) => (
        <div class="text-left border-l border-rule-strong pl-5">
          <p class="display text-4xl sm:text-5xl mb-2 text-bone leading-none tracking-tight" style="font-weight: 400;">
            {stat.figure}
          </p>
          <p class="font-mono text-[0.65rem] tracking-[0.12em] uppercase text-bone-mute leading-snug">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

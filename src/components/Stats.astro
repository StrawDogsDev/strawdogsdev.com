---
const featuredLionsgate = {
  figure: "92%",
  label: "Critics—Lionsgate feature, 2024",
  note: "The Best Christmas Pageant Ever · 97% Audiences · Top-40 box office",
};

const featuredCurriculum = {
  figure: "30",
  label: "Years of curriculum design",
  note: "FranklinCovey · VitalSmarts · ZengerFolkman · Chief Learning Officer for a Tony Robbins training partner",
};

const supporting = [
  { figure: "30+", label: "Trade nonfiction titles", note: "Leadership, sales, sports, behavior, memoir" },
  { figure: "250K+", label: "Copies sold (Simon & Schuster)", note: "Bad Unicorn trilogy · distributed internationally" },
];
---

<section id="track" class="section fade-in">
  <div class="wrap">
    <div style="display:flex; align-items:center; gap:0.85rem; margin-bottom:2.5rem;">
      <span class="eyebrow">Platte's Unmatched Track Record</span>
      <span class="rule-blue" style="flex:1; opacity:0.4;"></span>
    </div>

    <div class="track-bento">
      <!-- Row 1: Lionsgate moment (photo left, stat right) -->
      <figure class="photo-cell photo-cell--lionsgate">
        <img
          class="photo-main"
          src="/images/platteredcarpet2.jpg"
          alt="Platte F. Clark on the red carpet at the Lionsgate premiere of The Best Christmas Pageant Ever"
          loading="lazy"
        />
        <img
          class="photo-polaroid"
          src="/images/platteredcarpet.jpg"
          alt=""
          loading="lazy"
        />
        <figcaption>
          <span class="caption-label">From the Red Carpet</span>
          <em>The Best Christmas Pageant Ever</em> · Lionsgate, 2024
        </figcaption>
      </figure>

      <div class="card stat featured-stat featured-stat--lionsgate">
        <p class="stat-fig display">{featuredLionsgate.figure}</p>
        <div>
          <p class="stat-label">{featuredLionsgate.label}</p>
          <p class="stat-note">{featuredLionsgate.note}</p>
        </div>
      </div>

      <!-- Row 2: Tony Robbins moment (stat left, photo right — alternating rhythm) -->
      <div class="card stat featured-stat featured-stat--curriculum">
        <p class="stat-fig display">{featuredCurriculum.figure}</p>
        <div>
          <p class="stat-label">{featuredCurriculum.label}</p>
          <p class="stat-note">{featuredCurriculum.note}</p>
        </div>
      </div>

      <figure class="photo-cell photo-cell--tony">
        <img
          class="photo-main"
          src="/images/PandT.png"
          alt="Platte F. Clark with Tony Robbins"
          loading="lazy"
        />
        <figcaption>
          <span class="caption-label">Behind the Curriculum</span>
          With <em>Tony Robbins</em>
        </figcaption>
      </figure>

      <!-- Row 3: Supporting stats -->
      <div class="supporting-stats">
        {supporting.map((s) => (
          <div class="card stat">
            <p class="stat-fig display">{s.figure}</p>
            <div>
              <p class="stat-label">{s.label}</p>
              <p class="stat-note">{s.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .track-bento {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    grid-template-rows: auto auto auto;
    gap: 1rem;
  }

  /* ── Photo cells (shared) ─────────────────────── */
  .photo-cell {
    margin: 0;
    position: relative;
    overflow: hidden;
    border-radius: 2px;
    border: 1px solid var(--color-rule);
    background: #15171f;
  }
  .photo-main {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    filter: contrast(1.04) saturate(0.96);
  }
  .photo-cell::after {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 55%, rgba(15, 18, 27, 0.78) 100%);
    pointer-events: none;
  }
  .photo-cell figcaption {
    position: absolute;
    bottom: 1.3rem; left: 1.4rem;
    color: #f4f0e6;
    font-family: var(--font-display);
    font-style: italic;
    font-variation-settings: "opsz" 30;
    font-size: 0.95rem;
    line-height: 1.35;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.7);
    max-width: 65%;
    z-index: 3;
  }
  .photo-cell figcaption em { font-style: italic; }
  .photo-cell figcaption .caption-label {
    display: block;
    font-family: var(--font-body);
    font-style: normal;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(244, 240, 230, 0.85);
    margin-bottom: 0.45rem;
  }

  /* ── Lionsgate cell (row 1, col 1) ────────────── */
  .photo-cell--lionsgate {
    grid-column: 1; grid-row: 1;
    aspect-ratio: 4 / 5;
  }
  .photo-cell--lionsgate .photo-main {
    object-position: center 30%;
  }
  .photo-polaroid {
    position: absolute;
    bottom: 1.4rem; right: 1.2rem;
    width: 38%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 30%;
    padding: 0.45rem 0.45rem 1.1rem;
    background: #f8f4ec;
    border: 1px solid rgba(0, 0, 0, 0.15);
    box-shadow: 0 18px 32px -10px rgba(0, 0, 0, 0.55);
    transform: rotate(4deg);
    transform-origin: center center;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 2;
  }
  .photo-cell--lionsgate:hover .photo-polaroid {
    transform: rotate(-1.5deg) translateY(-4px);
  }

  /* ── Tony Robbins cell (row 2, col 2) ─────────── */
  .photo-cell--tony {
    grid-column: 2; grid-row: 2;
    aspect-ratio: 1 / 1;
  }
  .photo-cell--tony .photo-main {
    object-position: center center;
  }

  /* ── Featured stats ───────────────────────────── */
  .featured-stat {
    padding: 2.2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .featured-stat .stat-fig {
    font-size: clamp(4.5rem, 9vw, 7rem);
    line-height: 0.95;
  }
  .featured-stat .stat-label { font-size: 0.78rem; margin-bottom: 0.6rem; }
  .featured-stat .stat-note { font-size: 0.92rem; line-height: 1.5; }
  .featured-stat--lionsgate { grid-column: 2; grid-row: 1; }
  .featured-stat--curriculum { grid-column: 1; grid-row: 2; }

  /* ── Supporting stats row 3 ───────────────────── */
  .supporting-stats {
    grid-column: 1 / -1; grid-row: 3;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .stat { padding: 1.9rem 1.6rem; display: flex; flex-direction: column; justify-content: space-between; gap: 1.5rem; min-height: 180px; }
  .stat-fig { font-size: clamp(2.6rem, 4.5vw, 3.6rem); line-height: 1; color: var(--color-ink); }
  .stat-label { font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-blue); margin: 0 0 0.4rem; }
  .stat-note { font-size: 0.82rem; color: var(--color-ink-mute); line-height: 1.4; margin: 0; }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 860px) {
    .track-bento { grid-template-columns: 1fr; }
    .photo-cell--lionsgate, .photo-cell--tony,
    .featured-stat--lionsgate, .featured-stat--curriculum { grid-column: 1; grid-row: auto; }
    .photo-cell--tony { aspect-ratio: 4 / 3; }
    .supporting-stats { grid-column: 1; grid-row: auto; grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 460px) {
    .supporting-stats { grid-template-columns: 1fr; }
    .photo-polaroid { width: 44%; bottom: 1rem; right: 0.9rem; }
    .photo-cell figcaption { font-size: 0.85rem; max-width: 60%; }
  }
</style>

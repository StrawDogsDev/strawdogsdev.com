---
interface Props { cite?: string; }
const { cite } = Astro.props;
---

<section class="section fade-in">
  <div class="wrap quote-wrap">
    <blockquote class="quote display">
      <slot />
    </blockquote>
    {cite && <p class="quote-cite">— {cite}</p>}
  </div>
</section>

<style>
  .quote-wrap { max-width: 60ch; margin-left: auto; margin-right: auto; text-align: center; }
  .quote { font-size: clamp(1.7rem, 3.6vw, 3rem); line-height: 1.15; margin: 0; text-wrap: balance; }
  .quote-cite { font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-ink-mute); margin-top: 1.75rem; }
</style>
